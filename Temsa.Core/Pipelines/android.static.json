{
  "platform": "android",
  "analysisType": "static",
  "stages": [
    {
      "id": "static-analysis",
      "order": 1,
      "execution": "sequential",
      "runPolicy": "on-success",
      "tasks": [
        {
          "taskType": "decompile",
          "workerType": "static-analysis",
          "tool": "jadx",
          "order": 1,
          "parameters": {
            "outputFormat": "source"
          }
        },
        {
          "taskType": "sast",
          "workerType": "static-analysis",
          "tool": "semgrep",
          "order": 2,
          "parameters": {
            "ruleset": "full",
            "reportFormat": "json",
            "threads": 2
          }
        }
      ]
    }
  ]
}

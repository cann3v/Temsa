{
  "platform": "android",
  "analysisType": "dynamic",
  "parameters": {
    "packageName": "owasp.sat.agoat"
  },
  "stages": [
    {
      "id": "prepare",
      "order": 1,
      "execution": "sequential",
      "runPolicy": "on-success",
      "tasks": [
        {
          "taskType": "android-install-app",
          "workerType": "android-dynamic-analysis",
          "tool": "adb",
          "order": 1,
          "parameters": {
            "reinstall": true
          }
        },
        {
          "taskType": "android-clear-app-data",
          "workerType": "android-dynamic-analysis",
          "tool": "adb",
          "order": 2
        }
      ]
    },
    {
      "id": "interactive-analysis",
      "order": 2,
      "execution": "parallel",
      "runPolicy": "on-success",
      "tasks": [
        {
          "taskType": "android-dynamic-session",
          "workerType": "android-dynamic-analysis",
          "tool": "frida",
          "order": 1,
          "parameters": {
            "sessionTimeoutSeconds": 600,
            "scriptProfile": "android-basic",
            "enabledScripts": [],
            "disabledScripts": []
          }
        }
      ]
    },
    {
      "id": "cleanup",
      "order": 3,
      "execution": "sequential",
      "runPolicy": "always",
      "tasks": [
        {
          "taskType": "android-force-stop-app",
          "workerType": "android-dynamic-analysis",
          "tool": "adb",
          "order": 1
        },
        {
          "taskType": "android-uninstall-app",
          "workerType": "android-dynamic-analysis",
          "tool": "adb",
          "order": 2
        }
      ]
    }
  ]
}
